#!/usr/bin/env python3
"""Pre-push hook: auto-increment patch version in _version.py."""
import re
import subprocess
import sys
from pathlib import Path

VERSION_FILE = Path(__file__).parent.parent / "_version.py"


def bump_patch(version: str) -> str:
    major, minor, patch = version.split(".")
    return f"{major}.{minor}.{int(patch) + 1}"


def main() -> int:
    text = VERSION_FILE.read_text()
    m = re.search(r'__version__\s*=\s*"([^"]+)"', text)
    if not m:
        print("pre-push: could not find __version__ in _version.py", file=sys.stderr)
        return 1

    old = m.group(1)
    new = bump_patch(old)
    VERSION_FILE.write_text(text.replace(f'"{old}"', f'"{new}"'))

    subprocess.run(["git", "add", str(VERSION_FILE)], check=True)
    subprocess.run(
        ["git", "commit", "-m", f"Bump version to {new}"],
        check=True,
    )
    print(f"pre-push: bumped {old} → {new}")
    return 0


sys.exit(main())
